# ── LLM ───────────────────────────────────────────────────────────────────────
# Option A: GitHub Models (GPT-5 free via GitHub Models)
GITHUB_TOKEN=your_github_personal_access_token_here
# Option B: Direct OpenAI API key
OPENAI_API_KEY=

# ── Vector DB ─────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///data/features.db

# ── API Football (optional — for live match data) ─────────────────────────────
API_FOOTBALL_KEY=your_api_football_key_here

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
